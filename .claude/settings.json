{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "command": "pnpm verify",
        "timeout": 600000
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm dev*)",
      "Bash(pnpm build)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm e2e*)",
      "Bash(pnpm verify)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ]
  }
}
