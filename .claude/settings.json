{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck && pnpm lint && pnpm test && pnpm scan-images && pnpm build",
            "timeout": 600000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm dev*)",
      "Bash(pnpm build)",
      "Bash(pnpm test*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm e2e*)",
      "Bash(pnpm verify)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ]
  }
}
